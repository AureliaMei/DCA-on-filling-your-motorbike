import asyncio
import json
import os
import re
from datetime import datetime
from playwright.async_api import async_playwright

JSON_FILE = "pvoil_prices.json"


def log(step):
    print(f"\n[STEP] {step}")


def get_latest_saved_date():
    if not os.path.exists(JSON_FILE):
        print("[INFO] JSON file does not exist.")
        return None

    try:
        with open(JSON_FILE, "r", encoding="utf-8") as f:
            data = json.load(f)
            if not data:
                print("[INFO] JSON file is empty.")
                return None

            dates = [datetime.strptime(d, "%d-%m-%Y") for d in data.keys()]
            latest = max(dates)
            print(f"[INFO] Latest date in JSON: {latest}")
            return latest
    except Exception as e:
        print(f"[ERROR] Reading JSON failed: {e}")
        return None


async def crawl_pvoil_prices():

    log("Checking existing JSON file")
    latest_saved_date = get_latest_saved_date()

    async with async_playwright() as p:

        log("Launching browser")
        browser = await p.chromium.launch(headless=False)  # set False to see what's happening

        context = await browser.new_context()
        page = await context.new_page()

        url = "https://www.pvoil.com.vn/tin-gia-xang-dau"
        log(f"Navigating to {url}")

        await page.goto(url, wait_until="domcontentloaded")
        print("[INFO] Page loaded.")

        # Wait extra for JS
        await page.wait_for_timeout(3000)

        log("Checking if dropdown exists")

        # Debug: print available select elements
        selects = await page.locator("select").count()
        print(f"[DEBUG] Found {selects} <select> elements")

        custom_dropdowns = await page.locator(".select-selected").count()
        print(f"[DEBUG] Found {custom_dropdowns} .select-selected elements")

        # Try normal HTML select first (more stable)
        if selects > 0:
            log("Using standard <select> dropdown")
            dropdown = page.locator("select").first

            options = await dropdown.locator("option").all()
            print(f"[INFO] Found {len(options)} date options")

            dates_to_crawl = []

            for opt in options:
                date_text = (await opt.inner_text()).strip()
                val = await opt.get_attribute("value")

                if not val:
                    continue

                try:
                    current_date = datetime.strptime(date_text, "%d-%m-%Y")
                except:
                    continue

                if not latest_saved_date or current_date > latest_saved_date:
                    dates_to_crawl.append((val, date_text))

            print(f"[INFO] New dates to crawl: {len(dates_to_crawl)}")

            if not dates_to_crawl:
                print("Already up to date.")
                await browser.close()
                return

            # Load existing JSON
            if os.path.exists(JSON_FILE):
                with open(JSON_FILE, "r", encoding="utf-8") as f:
                    all_data = json.load(f)
            else:
                all_data = {}

            # Crawl each date
            for val, date_text in dates_to_crawl:

                log(f"Crawling date {date_text}")

                await dropdown.select_option(value=val)
                await page.wait_for_timeout(2000)

                rows = await page.locator("table tbody tr").all()
                print(f"[INFO] Found {len(rows)} rows")

                fuels = []

                for row in rows:
                    cols = await row.locator("td").all_inner_texts()

                    if len(cols) >= 3:
                        fuel_type = cols[1].strip()
                        price_raw = cols[2].strip()

                        price_clean = (
                            price_raw.replace(" đ", "")
                            .replace(".", "")
                            .replace(",", "")
                        )

                        try:
                            price_vnd = int(price_clean)
                        except:
                            price_vnd = 0

                        fuels.append({
                            "fuel_type": fuel_type,
                            "price_vnd": price_vnd
                        })

                # Extract time
                page_text = await page.locator("body").inner_text()
                match = re.search(r"(\d{1,2}:\d{2})", page_text)
                time_of_change = match.group(1) if match else "Unknown"

                all_data[date_text] = {
                    "time_of_change": time_of_change,
                    "fuels": fuels
                }

            log("Saving JSON file")

            with open(JSON_FILE, "w", encoding="utf-8") as f:
                json.dump(all_data, f, ensure_ascii=False, indent=4)

            print("[SUCCESS] JSON updated.")

        else:
            print("[ERROR] No <select> dropdown found. Site structure may have changed.")

        await browser.close()
        print("[DONE]")


if __name__ == "__main__":
    asyncio.run(crawl_pvoil_prices())